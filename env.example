---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
import { siteInfo } from "@i18n/ui";
---

<BaseLayout
  title={`Contact | ${siteInfo.englishName}`}
  description="Contact Zihua Luo, FRM for thoughtful conversations around finance, research, analytics, learning, and early-career growth"
  lang="en"
  alternateHref="/zh/contact/"
  canonicalPath="/contact/"
>
  <section class="finance-shell py-14 sm:py-20">
    <div class="container-page relative z-10">
      <PageHeader
        eyebrow="Contact"
        title="Open to thoughtful conversations"
        description="If you have an idea worth discussing, a perspective to exchange, or a conversation around finance, research, analytics, learning, or early-career growth, feel free to reach out"
      />
    </div>
  </section>

  <section class="surface-section contact-section py-20 sm:py-28">
    <div class="container-page flex min-h-[44vh] items-center">
      <div class="premium-card mx-auto grid min-h-[280px] w-full max-w-3xl content-center rounded-3xl p-7 shadow-lift sm:p-9">
        <p class="eyebrow">Email</p>
        <a
          class="mt-6 inline-flex w-full flex-col gap-5 rounded-2xl border border-accent/30 bg-[linear-gradient(135deg,rgba(56,189,248,0.16),rgba(167,139,250,0.12),rgba(255,255,255,0.04))] p-5 text-left shadow-card transition hover:-translate-y-1 hover:border-accent/60 hover:shadow-lift sm:flex-row sm:items-center sm:justify-between sm:p-6"
          href={siteInfo.socials.email}
          data-track-event="Click Email"
        >
          <span>
            <span class="block text-sm font-bold uppercase tracking-[0.16em] text-muted">Reach me at</span>
            <span class="mt-2 block break-all display-heading text-3xl font-semibold text-ink sm:text-4xl">{siteInfo.emailAddress}</span>
          </span>
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-full border border-accent/35 bg-white/[0.08] text-accent shadow-[0_0_24px_rgba(56,189,248,0.22)]" aria-hidden="true">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
