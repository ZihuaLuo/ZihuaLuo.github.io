---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import SectionTitle from "@components/SectionTitle.astro";
import NowDashboard from "@components/NowDashboard.astro";
import ThoughtCard from "@components/ThoughtCard.astro";
import NoteCard from "@components/NoteCard.astro";
import TimelineItem from "@components/TimelineItem.astro";
import CTAButton from "@components/CTAButton.astro";
import { operatingPrinciples } from "@data/principles";
import { entrySlug, langPath } from "@i18n/routes";
import { siteInfo } from "@i18n/ui";

const lang = "en";
const includeDrafts = !import.meta.env.PROD;
const latestThoughts = (await getCollection(
  "thoughts",
  ({ data }) => data.language === lang && (includeDrafts || !data.draft),
))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const latestNotes = (await getCollection(
  "notes",
  ({ data }) => data.language === lang && (includeDrafts || !data.draft),
))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const timelinePreview = (await getCollection(
  "timeline",
  ({ data }) => data.language === lang && (includeDrafts || !data.draft),
))
  .sort((a, b) => (b.data.order ?? 0) - (a.data.order ?? 0))
  .slice(0, 10);

const principles = operatingPrinciples[lang];
---

<BaseLayout
  title={`${siteInfo.englishName} | Finance, Research & Analytics`}
  description="Finance, research analytics, risk-aware thinking, and a bilingual archive of learning and reflection"
  lang={lang}
  alternateHref="/zh/"
  canonicalPath="/"
>
  <Hero lang={lang} />

  <section id="timeline" class="timeline-stage py-18 sm:py-24">
    <div class="container-page relative z-10">
      <div class="grid gap-8 lg:grid-cols-[0.86fr_1.14fr] lg:items-end">
        <SectionTitle
          eyebrow="Selected Experience & Milestones"
          title="A curated timeline of roles, learning moments, and defining milestones"
          description="A long-form professional journey system for roles, learning, preparation, and milestones that can extend naturally as new experience is added"
        />
        <div class="premium-card rounded-2xl p-5">
          <p class="text-sm font-semibold leading-7 text-muted">
            Each entry follows a consistent logo plus role-and-company format; milestones receive a refined glow while the timeline stays balanced and scalable
          </p>
        </div>
      </div>
      <div class="timeline-rail relative mt-14 grid gap-y-12 before:absolute before:left-2.5 before:top-0 before:h-full before:w-px lg:gap-y-20 lg:before:left-1/2">
        {timelinePreview.map((entry, index) => (
          <div class="grid lg:grid-cols-2 lg:gap-x-16">
            <div class={index % 2 === 0 ? "lg:col-start-1" : "lg:col-start-2"}>
              <TimelineItem entry={entry} align={index % 2 === 0 ? "left" : "right"} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="principles" class="surface-section principles-section py-18 sm:py-24">
    <div class="container-page">
      <SectionTitle
        eyebrow="Operating Principles"
        title="How I turn learning, analysis, and reflection into a personal brand system"
        description="A concise view of how I think, how I learn, and what kind of professional identity I am building"
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {principles.map((card) => (
          <article class="premium-card group overflow-hidden rounded-2xl p-6 transition duration-300 hover:-translate-y-1 hover:border-accent/60 hover:shadow-lift">
            <div class="mb-6 flex items-center justify-between gap-4">
              <span class="grid h-12 w-12 place-items-center rounded-2xl border border-accent/30 bg-white/[0.08] text-sm font-extrabold text-ink shadow-[0_0_24px_rgba(124,58,237,0.18)]">
                {card.index}
              </span>
              <span class="rounded-full border border-white/[0.12] bg-white/[0.07] px-2.5 py-1 text-xs font-bold text-accent">{card.label}</span>
            </div>
            <h3 class="display-heading text-2xl font-semibold leading-tight text-ink">{card.title}</h3>
            <p class="mt-4 min-h-[56px] text-sm leading-7 text-body">{card.description}</p>
            <div class="mt-6 flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.16em] text-gold">
              <span class="h-px flex-1 bg-gradient-to-r from-accent/70 to-transparent" aria-hidden="true"></span>
              {card.signal}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="surface-section now-section py-18 sm:py-24">
    <div class="container-page">
      <NowDashboard lang={lang} />
    </div>
  </section>

  <section class="surface-section archive-section archive-section--thoughts py-18 sm:py-24">
    <div class="container-page">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
        <SectionTitle
          eyebrow="Latest Thoughts"
          title="Recent essays from the thinking archive"
          description="Polished writing on finance, decisions, learning, career, and risk-aware judgment"
        />
        <CTAButton href={langPath(lang, "/thoughts/")} label="All Thoughts" variant="secondary" />
      </div>
      <div class="mt-10 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
        {latestThoughts.map((entry) => (
          <ThoughtCard entry={entry} lang={lang} href={langPath(lang, `/thoughts/${entrySlug(entry.id)}/`)} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-panel archive-section archive-section--notes py-18 sm:py-24">
    <div class="container-page">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
        <SectionTitle
          eyebrow="Learning System"
          title="Notes that turn study into reusable structure"
          description="A growing knowledge archive for finance concepts, CFA study, and analytics frameworks"
        />
        <CTAButton href={langPath(lang, "/notes/")} label="View Notes" variant="secondary" />
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {latestNotes.map((entry) => (
          <NoteCard entry={entry} lang={lang} href={langPath(lang, `/notes/${entrySlug(entry.id)}/`)} />
        ))}
      </div>
    </div>
  </section>

  <section id="contact-cta" class="surface-section contact-section py-20 sm:py-28">
    <div class="container-page">
      <div class="premium-card grid min-h-[220px] gap-8 rounded-3xl p-7 shadow-lift sm:p-9 md:grid-cols-[1fr_auto] md:items-center">
        <div class="max-w-3xl">
          <p class="eyebrow">Contact</p>
          <h2 class="mt-3 display-heading text-3xl font-semibold leading-tight text-ink">Open to thoughtful conversations around finance, research, and analytics</h2>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-body">Share a question, perspective, or idea where finance, research, and structured judgment meet</p>
        </div>
        <div class="flex md:justify-end">
          <CTAButton href={langPath(lang, "/contact/")} label="Start a Conversation" variant="secondary" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
