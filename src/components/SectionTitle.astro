---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  inverse?: boolean;
}

const { eyebrow, title, description, align = "left", inverse = false } = Astro.props;
const alignment = align === "center" ? "mx-auto text-center" : "";
const titleClass = "title-flow title-flow--section bg-[linear-gradient(135deg,#FFFFFF_0%,#DBEAFE_48%,#C4B5FD_100%)] bg-clip-text text-transparent";
const descClass = "text-muted";
---

<div class={`max-w-3xl overflow-visible ${alignment}`}>
  {eyebrow && (
    <p class={`eyebrow mb-3 inline-flex items-center gap-2 ${inverse ? "text-gold" : ""}`}>
      <span class="h-px w-8 bg-gold/80" aria-hidden="true"></span>
      {eyebrow}
    </p>
  )}
  <h2 class={`display-heading text-4xl font-semibold leading-[1.12] ${titleClass} sm:text-5xl lg:text-6xl`}>{title}</h2>
  {description && <p class={`mt-4 text-base leading-7 ${descClass} sm:text-lg`}>{description}</p>}
</div>
