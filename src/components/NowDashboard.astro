    eyebrow: "Measured Achievement Archive",
    title: "Impact Metrics",
    subtitle:
      "A quantified record of academic performance, credentials, work execution, professional networking, and analytical scale",
    statusItems: [
      { label: "Academic Record", value: "GPA 3.90/4.00", level: 98, tone: "cyan" as Tone },
      { label: "Credential Speed", value: "Full FRM in 6 Months", level: 88, tone: "violet" as Tone },
      { label: "CFA Preparation", value: "CFA I/II Study 730 Hours", level: 73, tone: "gold" as Tone },
      { label: "Capital Exposure", value: "$3B+ AUM", level: 92, tone: "blue" as Tone },
    ],
    metricTitle: "Quantified Highlights",
    metricSubtitle: "Sustained learning, routine discipline, and personal operating standards",
    heroMetrics: [
      { label: "Online Learning", value: "1,800 Hours", detail: "Recorded learning accumulation", tone: "cyan" as Tone },
      { label: "Annual Reviews", value: "4 Years", detail: "Completed every year", tone: "cyan" as Tone },
      { label: "Wake-Up Time", value: "6 AM", detail: "Daily operating rhythm", tone: "violet" as Tone },
