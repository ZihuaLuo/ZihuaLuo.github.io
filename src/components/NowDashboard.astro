      { label: "Reliability", value: "100%", level: 100, tone: "gold" as Tone },
      { label: "To-Do List Execution", value: "8h", level: 88, tone: "blue" as Tone },
      { label: "Office & Coding Tools", value: "15+", level: 90, tone: "violet" as Tone },
      { label: "Evidence Groups", value: "12 Nodes", level: 86, tone: "cyan" as Tone },
    ],
  },
  zh: {
    eyebrow: "可量化成果档案",
    title: "量化成果",
    subtitle: "记录学业、证书、执行负载、职业社交与分析规模",
    statusItems: [
      { label: "学业记录", value: "GPA 3.90/4.00", level: 98, tone: "cyan" as Tone },
      { label: "证书速度", value: "6 个月通过全部 FRM", level: 88, tone: "violet" as Tone },
      { label: "CFA 备考", value: "CFA 一/二级学习 730 小时", level: 73, tone: "gold" as Tone },
      { label: "资金规模", value: "超 $3B AUM", level: 92, tone: "blue" as Tone },
    ],
    metricTitle: "量化亮点",
    metricSubtitle: "持续学习、日常纪律与个人执行标准",
    heroMetrics: [
      { label: "线上学习", value: "1,800 小时", detail: "累计学习记录", tone: "cyan" as Tone },
      { label: "年度总结", value: "4 年", detail: "连续完成年度复盘", tone: "cyan" as Tone },
      { label: "起床时间", value: "6 AM", detail: "稳定作息节奏", tone: "violet" as Tone },
    ],
    credentialTitle: "学术广度",
    credentialSubtitle: "学业结构与跨方向准备",
    credentialItems: [
      { label: "辅修数量", value: "3 个", detail: "跨方向学业负载", level: 62, tone: "blue" as Tone },
      { label: "德格鲁特排名", value: "前 10%", detail: "保持在商学院高表现群体", level: 90, tone: "cyan" as Tone },
      { label: "核心学习方向", value: "4 个", detail: "金融、经济、分析与高阶数学", level: 76, tone: "gold" as Tone },
      { label: "主修方向", value: "金融", detail: "荣誉商科学士核心方向", level: 86, tone: "violet" as Tone },
      { label: "商科项目", value: "荣誉商科", detail: "荣誉商科学士项目", level: 70, tone: "cyan" as Tone },
    ],
    executionTitle: "职业社交与执行负载",
    executionSubtitle: "关系建立、工作并行、多任务处理与高强度交付",
    executionItems: [
      { label: "职业活动", value: "20+", detail: "参加职业社交活动", tone: "cyan" as Tone },
      { label: "咖啡交流", value: "100+", detail: "完成职业交流", tone: "violet" as Tone },
      { label: "同时进行的工作", value: "3 份", detail: "并行推进工作流", tone: "gold" as Tone },
      { label: "多任务负载", value: "8+", detail: "同时处理的任务数量", tone: "blue" as Tone },
      { label: "最晚工作时间", value: "3 AM", detail: "高强度交付节点", tone: "violet" as Tone },
      { label: "跟进记录", value: "120+", detail: "会后跟进与记录", tone: "cyan" as Tone },
    ],
    scaleTitle: "分析规模",
    scaleSubtitle: "用数据深度、审核数量、申报文件跨度、商业阅读、报税金额与转化表现呈现真实分析工作量",
    scaleOutcomeCards: [
      { label: "分析维度覆盖", value: "7 类", tone: "blue" as Tone },
      { label: "动态仪表盘", value: "4+", tone: "cyan" as Tone },
      { label: "成本优化", value: "30%", tone: "gold" as Tone },
    ],
    scaleCoreLabel: "数据分析规模",
    scaleCoreValue: "100K+",
    scaleItems: [
      { label: "基金报表审核", value: "50+", detail: "审核数量", level: 72, tone: "violet" as Tone },
      { label: "SEC 申报文件跨度", value: "30 年", detail: "申报文件历史", level: 64, tone: "gold" as Tone },
      { label: "商业文章审阅", value: "2,000+", detail: "商业内容阅读与审阅", level: 88, tone: "cyan" as Tone },
      { label: "报税累计金额", value: "$100K+", detail: "累计处理金额", level: 68, tone: "gold" as Tone },
      { label: "客户转化率", value: "15%+", detail: "转化表现", level: 80, tone: "blue" as Tone },
    ],
    networkTitle: "成果网络",
    networkSubtitle: "把学业基础、关系触达、执行系统与分析产出组织成一条可追踪的成果流",
    networkLegend: "成果流",
    networkCoreLabel: "成果引擎",
    networkCoreValue: "12 个信号",
    networkStages: [
      {
        title: "基础资产",
        value: "3.90 GPA",
        tone: "cyan" as Tone,
        items: ["学业", "荣誉商科", "CFA / FRM"],
      },
      {
        title: "关系触达",
        value: "120+ 记录",
        tone: "violet" as Tone,
        items: ["职业活动", "咖啡交流", "跟进记录"],
      },
      {
        title: "执行系统",
        value: "3 份 / 8+",
        tone: "gold" as Tone,
        items: ["工作负载", "工具栈", "交付节奏"],
      },
      {
        title: "分析产出",
        value: "100K+",
        tone: "blue" as Tone,
        items: ["研究仪表盘", "基金审核", "SEC 申报文件", "客户转化"],
      },
    ],
    networkStats: [
      { label: "交付可靠性", value: "100%", level: 100, tone: "gold" as Tone },
      { label: "待办清单执行", value: "8h", level: 88, tone: "blue" as Tone },
      { label: "办公与编程工具", value: "15+", level: 90, tone: "violet" as Tone },
      { label: "证据节点", value: "12 个", level: 86, tone: "cyan" as Tone },
    ],
  },
}[lang];

const trackColor = (tone: Tone) =>
  tone === "cyan"
    ? "var(--cyan)"
    : tone === "violet"
      ? "var(--text-violet)"
      : tone === "gold"
        ? "var(--accent-warm)"
        : "var(--text-cyan)";
---

<div class="impact-dashboard relative">
  {showHeader && (
    <div class="impact-header mb-9 grid gap-6 lg:grid-cols-[0.76fr_1.24fr] lg:items-end">
      <div class="max-w-3xl overflow-visible">
        <h2 class="display-heading title-flow title-flow--section bg-[linear-gradient(135deg,#FFFFFF_0%,#DBEAFE_46%,#7DD3FC_72%,#C4B5FD_100%)] bg-clip-text text-4xl font-semibold leading-[1.12] text-transparent sm:text-5xl lg:text-6xl">
          {dashboardText.title}
        </h2>
        <p class="mt-4 text-base leading-8 text-muted sm:text-lg">{dashboardText.subtitle}</p>
      </div>

      <div class="impact-status-grid grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        {dashboardText.statusItems.map((item) => (
          <div class={`impact-status impact-tone-${item.tone} ${item.value.length > 12 ? "impact-status--compact" : ""}`}>
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <i style={`width:${item.level}%; --bar:${trackColor(item.tone)}`}></i>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="impact-grid">
    <section class="impact-panel impact-panel--scoreboard">
      <div class="impact-panel__head">
        <div>
          <p class="eyebrow">{dashboardText.metricTitle}</p>
          <p class="mt-3 text-sm leading-7 text-body">{dashboardText.metricSubtitle}</p>
        </div>
      </div>

      <div class="metric-wall mt-6">
        {dashboardText.heroMetrics.map((item) => (
          <article class={`metric-tile impact-tone-${item.tone}`}>
            <span class="metric-tile__label">{item.label}</span>
            <strong class="metric-tile__value">{item.value}</strong>
            <span class="metric-tile__detail">{item.detail}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="impact-panel impact-panel--credentials">
      <div class="impact-panel__head">
        <div>
          <p class="eyebrow">{dashboardText.credentialTitle}</p>
          <p class="mt-3 text-sm leading-7 text-body">{dashboardText.credentialSubtitle}</p>
        </div>
      </div>

      <div class="achievement-bars mt-6">
        {dashboardText.credentialItems.map((item) => (
          <div class={`achievement-row impact-tone-${item.tone}`}>
            <div class="achievement-row__top">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
            <p>{item.detail}</p>
            <div class="achievement-track" aria-hidden="true">
              <span style={`width:${item.level}%; --bar:${trackColor(item.tone)}`}></span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="impact-panel impact-panel--execution">
      <div class="impact-panel__head">
        <div>
          <p class="eyebrow">{dashboardText.executionTitle}</p>
          <p class="mt-3 text-sm leading-7 text-body">{dashboardText.executionSubtitle}</p>
        </div>
      </div>

      <div class="execution-stack mt-6">
        {dashboardText.executionItems.map((item) => (
          <article class={`execution-row impact-tone-${item.tone}`}>
            <div>
              <span>{item.label}</span>
              <p>{item.detail}</p>
            </div>
            <strong>{item.value}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="impact-panel impact-panel--scale">
      <div class="impact-panel__head impact-panel__head--split impact-panel__head--scale">
        <div class="scale-copy">
          <p class="eyebrow">{dashboardText.scaleTitle}</p>
          <p class="scale-copy__subtitle">{dashboardText.scaleSubtitle}</p>
        </div>
        <div class="scale-lead-grid" aria-label={dashboardText.scaleTitle}>
          {dashboardText.scaleOutcomeCards.map((item) => (
            <article class={`scale-lead impact-tone-${item.tone}`}>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </article>
          ))}
        </div>
      </div>

      <div class="scale-visual mt-5">
        <div class="scale-radar" aria-hidden="true">
          <div class="scale-radar__ring scale-radar__ring--one"></div>
          <div class="scale-radar__ring scale-radar__ring--two"></div>
          <div class="scale-radar__core">
            <span>{dashboardText.scaleCoreValue}</span>
            <small>{dashboardText.scaleCoreLabel}</small>
          </div>
        </div>

        <div class="scale-bars">
          {dashboardText.scaleItems.map((item) => (
            <div class={`scale-bar impact-tone-${item.tone}`}>
              <div class="scale-bar__top">
                <span>{item.label}</span>
                <strong>{item.value}</strong>
              </div>
              <p>{item.detail}</p>
              <div class="scale-bar__track" aria-hidden="true">
                <span style={`width:${item.level}%; --bar:${trackColor(item.tone)}`}></span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="impact-panel impact-panel--network">
      <div class="impact-panel__head impact-panel__head--split">
        <div>
          <p class="eyebrow">{dashboardText.networkTitle}</p>
          <p class="mt-3 max-w-3xl text-sm leading-7 text-body">{dashboardText.networkSubtitle}</p>
        </div>
        <span class="network-legend">{dashboardText.networkLegend}</span>
      </div>

      <div class="impact-flow mt-7">
        <div class="impact-flow__scene">
          <svg class="impact-flow__ribbons" viewBox="0 0 1000 520" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id={`flow-primary-${lang}`} x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#67E8F9" stop-opacity="0.12" />
                <stop offset="34%" stop-color="#C4B5FD" stop-opacity="0.56" />
                <stop offset="66%" stop-color="#D6A85C" stop-opacity="0.48" />
                <stop offset="100%" stop-color="#38BDF8" stop-opacity="0.14" />
              </linearGradient>
              <linearGradient id={`flow-secondary-${lang}`} x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#38BDF8" stop-opacity="0.15" />
                <stop offset="50%" stop-color="#67E8F9" stop-opacity="0.5" />
                <stop offset="100%" stop-color="#C4B5FD" stop-opacity="0.18" />
              </linearGradient>
              <radialGradient id={`flow-core-glow-${lang}`} cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#E0F2FE" stop-opacity="0.55" />
                <stop offset="45%" stop-color="#67E8F9" stop-opacity="0.16" />
                <stop offset="100%" stop-color="#0B1226" stop-opacity="0" />
              </radialGradient>
            </defs>
            <ellipse class="impact-flow__halo" cx="500" cy="260" rx="262" ry="150" />
            <path class="impact-flow__ribbon impact-flow__ribbon--wide" d="M74 162 C210 80 338 214 500 260 S760 430 930 336" stroke={`url(#flow-primary-${lang})`} />
            <path class="impact-flow__ribbon" d="M90 382 C250 462 342 304 500 260 S738 74 906 152" stroke={`url(#flow-secondary-${lang})`} />
            <path class="impact-flow__ribbon impact-flow__ribbon--fine" d="M108 260 C242 218 368 218 500 260 S748 318 892 260" />
            <path class="impact-flow__connector impact-flow__connector--one" d="M182 142 C292 146 386 182 500 260" />
            <path class="impact-flow__connector impact-flow__connector--two" d="M276 404 C350 356 422 314 500 260" />
            <path class="impact-flow__connector impact-flow__connector--three" d="M724 142 C638 162 570 204 500 260" />
            <path class="impact-flow__connector impact-flow__connector--four" d="M820 404 C712 376 600 314 500 260" />
            <circle class="impact-flow__core-glow" cx="500" cy="260" r="148" fill={`url(#flow-core-glow-${lang})`} />
          </svg>

          <div class="impact-flow__core">
            <span>{dashboardText.networkCoreLabel}</span>
            <strong>{dashboardText.networkCoreValue}</strong>
          </div>

          <div class="impact-flow__stages">
            {dashboardText.networkStages.map((stage, index) => (
              <article class={`impact-flow__stage impact-flow__stage--${index + 1} impact-tone-${stage.tone}`} style={`--stage:${trackColor(stage.tone)}; --index:${index}`}>
                <span class="impact-flow__node" aria-hidden="true"></span>
                <div class="impact-flow__stage-top">
                  <span>{stage.title}</span>
                  <strong>{stage.value}</strong>
                </div>
                <div class="impact-flow__chips">
                  {stage.items.map((item) => (
                    <span>{item}</span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

      <div class="network-stat-grid mt-5">
        {dashboardText.networkStats.map((item) => (
          <article class={`network-stat impact-tone-${item.tone}`}>
            <div class="network-stat__top">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </div>
            <div class="network-stat__track" aria-hidden="true">
              <span style={`width:${item.level}%; --bar:${trackColor(item.tone)}`}></span>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</div>

<style>
  .impact-dashboard::before {
    background:
      radial-gradient(ellipse at 58% 8%, rgba(var(--rgb-cyan), 0.11), transparent 32rem),
      radial-gradient(ellipse at 82% 26%, rgba(var(--rgb-violet), 0.13), transparent 34rem);
    content: "";
    filter: blur(8px);
    inset: -4rem -2rem auto;
    height: 30rem;
    opacity: 0.48;
    pointer-events: none;
    position: absolute;
    contain: paint;
  }

  .impact-grid {
    display: grid;
    gap: 1.35rem;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    position: relative;
    z-index: 1;
  }

  .impact-panel,
  .impact-status,
  .metric-tile,
  .execution-row,
  .scale-lead {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.095), rgba(255, 255, 255, 0.04)),
      rgba(var(--rgb-bg-base), 0.42);
    box-shadow:
      0 18px 46px rgba(var(--rgb-bg-base), 0.3),
      0 0 26px rgba(var(--rgb-cyan), 0.045),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    contain: paint;
  }

  .impact-panel {
    border-radius: 1.7rem;
    overflow: hidden;
    padding: 1.55rem;
    position: relative;
  }

  .impact-panel::before {
    background:
      linear-gradient(90deg, rgba(var(--rgb-cyan-soft), 0.09) 1px, transparent 1px),
      linear-gradient(180deg, rgba(var(--rgb-violet-soft), 0.08) 1px, transparent 1px);
    background-size: 32px 32px;
    content: "";
    inset: 0;
    opacity: 0.12;
    pointer-events: none;
    position: absolute;
  }

  .impact-panel > * {
    position: relative;
    z-index: 1;
  }

  .impact-panel--scoreboard,
  .impact-panel--scale {
    grid-column: 1 / -1;
  }

  .impact-panel--scale {
    order: 1;
  }

  .impact-panel--scoreboard {
    order: 2;
  }

  .impact-panel--credentials {
    grid-column: span 7;
    order: 3;
  }

  .impact-panel--execution {
    grid-column: span 5;
    order: 4;
  }

  .impact-panel--network {
    grid-column: 1 / -1;
    order: 5;
  }

  .impact-panel__head {
    align-items: start;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .impact-panel__head--split {
    align-items: center;
