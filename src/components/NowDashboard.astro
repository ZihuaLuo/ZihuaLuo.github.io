      { label: "Core Study Areas", value: "4", detail: "Finance, economics, analytics, and advanced math", level: 76, tone: "gold" as Tone },
      { label: "Major Focus", value: "Finance", detail: "Honours commerce concentration", level: 86, tone: "violet" as Tone },
      { label: "Program Track", value: "Honours BCom", detail: "Honours commerce program", level: 70, tone: "cyan" as Tone },
    ],
    executionTitle: "Professional Networking & Execution Load",
    executionSubtitle: "Relationship-building, role volume, multitasking, and delivery intensity",
    executionItems: [
      { label: "Professional Events", value: "20+", detail: "Networking events attended", tone: "cyan" as Tone },
      { label: "Coffee Chats", value: "100+", detail: "Career conversations completed", tone: "violet" as Tone },
      { label: "Concurrent Jobs", value: "3 Jobs", detail: "Workstreams managed in parallel", tone: "gold" as Tone },
      { label: "Multitasking Load", value: "8+", detail: "Active responsibilities handled at once", tone: "blue" as Tone },
      { label: "Latest Work Time", value: "3 AM", detail: "Peak late-cycle execution", tone: "violet" as Tone },
      { label: "Follow-Up Notes", value: "120+", detail: "Post-conversation tracking", tone: "cyan" as Tone },
    ],
    scaleTitle: "Analysis Scale",
    scaleSubtitle: "Data depth, review volume, filing history, commercial reading, tax exposure, and conversion results",
    scaleOutcomeCards: [
      { label: "Analysis Dimensions", value: "7", tone: "blue" as Tone },
      { label: "Dashboards Built", value: "4+", tone: "cyan" as Tone },
      { label: "Cost Reduction", value: "30%", tone: "gold" as Tone },
    ],
    scaleCoreLabel: "Data Points Analyzed",
    scaleCoreValue: "100K+",
    scaleItems: [
      { label: "Fund Reports Reviewed", value: "50+", detail: "Reviews", level: 72, tone: "violet" as Tone },
      { label: "SEC Filings Reviewed", value: "30 Years", detail: "Filing History", level: 64, tone: "gold" as Tone },
      { label: "Business Articles", value: "2,000+", detail: "Commercial writing reviewed", level: 88, tone: "cyan" as Tone },
      { label: "Tax Filing Amount", value: "$100K+", detail: "Cumulative filing value", level: 68, tone: "gold" as Tone },
      { label: "Client Conversion", value: "15%+", detail: "Conversion performance", level: 80, tone: "blue" as Tone },
    ],
    networkTitle: "Evidence Network",
    networkSubtitle: "A layered flow from academic base and relationship reach into execution, analysis, and measurable outcomes",
    networkLegend: "Impact Flow",
    networkCoreLabel: "Outcome Engine",
    networkCoreValue: "12 Signals",
    networkStages: [
      {
        title: "Foundation",
        value: "3.90 GPA",
        tone: "cyan" as Tone,
        items: ["Academics", "Honours BCom", "CFA / FRM"],
      },
      {
        title: "Relationship Reach",
        value: "120+ Notes",
        tone: "violet" as Tone,
        items: ["Professional Events", "Coffee Chats", "Follow-Up Notes"],
      },
      {
        title: "Execution System",
        value: "3 Jobs / 8+",
        tone: "gold" as Tone,
