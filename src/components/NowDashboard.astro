---
import type { Language } from "@i18n/routes";

interface Props {
  lang: Language;
  showHeader?: boolean;
}

const { lang, showHeader = true } = Astro.props;

type Tone = "cyan" | "violet" | "gold" | "blue";

const dashboardText = {
