---
import SectionTitle from "@components/SectionTitle.astro";
import { creditEntries, type CreditTier } from "@data/credits";
import { type Language } from "@i18n/routes";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const zhRoleOrganizations = [
  "加拿大帝国商业银行梅隆信托",
  "道明银行资产管理",
  "EQ Capital Partners",
  "Agentis Capital",
  "Tokoro Capital",
  "Gent Commodity",
  "RER-RECONOCER",
  "麦克马斯特大学",
  "加拿大帝国商业银行",
  "加拿大皇家银行",
  "淡水河谷基本金属",
  "蒙特利尔银行",
  "加拿大丰业银行",
  "国泰君安国际",
  "国泰世华银行",
  "中化国际石油",
  "天弘资产管理",
  "德赛西威欧洲",
  "布鲁克菲尔德",
  "Green Street",
  "LMR Partners",
  "Vita Group",
  "Citco 集团",
  "Wealthsimple",
  "中信里昂",
  "道明证券",
  "长江证券",
  "中信银行",
  "富达投资",
  "贝伦贝格",
  "ActivumSG",
  "Landsec",
  "Hiscox",
  "ASBIS",
  "第一资本",
  "道明银行",
  "麦克森",
  "埃森哲",
  "毕马威",
  "黑石",
  "高盛",
  "安永",
  "德勤",
  "腾讯",
].sort((left, right) => right.length - left.length);

const splitZhRoleLabel = (roleLabel: string) => {
  const organization = zhRoleOrganizations.find(
    (candidate) => roleLabel === candidate || roleLabel.startsWith(`${candidate} `),
  );

  if (!organization) {
    return [{ text: roleLabel, kind: "single" }];
  }

  const role = roleLabel.slice(organization.length).trim();
  return role
    ? [
        { text: organization, kind: "org" },
        { text: role, kind: "role" },
      ]
    : [{ text: organization, kind: "single" }];
};

const entries = creditEntries.map((entry) => ({
  ...entry,
  roleLabel: lang === "zh" ? entry.roleZh : entry.role,
  roleLines: lang === "zh" ? splitZhRoleLabel(entry.roleZh) : [{ text: entry.role, kind: "single" }],
}));

const copy = {
  en: {
    eyebrow: "Credit",
    title: "A searchable map of the people behind the progress",
    description:
      "Names, roles, and the professional context of people whose guidance, trust, and shared standards shaped this work.",
    searchLabel: "Search credits",
    searchPlaceholder: "Search by name, role, or organization...",
    directoryLabel: "Credit directory",
    letterLabel: "Filter by first name",
    all: "All",
    sort: "Sort",
    hugeTitle: "Huge Thanks",
    hugeDescription: "People whose support, mentorship, and trust sit at the deepest layer of this journey.",
    creditsTitle: "Credits",
    creditsDescription: "A broader network of mentors, peers, and professionals who shaped the path forward.",
    empty: "No matching credits yet. Try another name, role, or letter.",
    loadMore: "Load more",
    showing: "Showing",
    of: "of",
    people: "people",
  },
  zh: {
    eyebrow: "致谢",
    title: "把感谢名单整理成可搜索的关系地图",
    description:
      "这里记录那些在我成长过程中给予过机会、信任、指导与支持的人。名单会持续增加，因此页面采用懒绘制与搜索筛选，保证完整名单仍然保持轻快。",
    searchLabel: "搜索致谢名单",
    searchPlaceholder: "按姓名、职位或机构搜索...",
    directoryLabel: "致谢名单目录",
    letterLabel: "按名字首字母筛选",
    all: "全部",
    sort: "排序",
    hugeTitle: "特别致谢",
    hugeDescription:
      "他们在我人生和职业发展的关键阶段给予了我重要的机会、信任与支持。",
    creditsTitle: "致谢名单",
    creditsDescription: "更多导师、同伴与专业人士，共同影响了我继续向前的路径。",
    empty: "没有匹配结果，可以尝试其他姓名、职位或首字母。",
    loadMore: "加载更多",
    showing: "已显示",
    of: "共",
    people: "人",
  },
}[lang];

const tiers: { tier: CreditTier; title: string; description: string }[] = [
  { tier: "huge", title: copy.hugeTitle, description: copy.hugeDescription },
  { tier: "credit", title: copy.creditsTitle, description: copy.creditsDescription },
];
const alphabet = Array.from("ABCDEFGHIJKLMNOPQRSTUVWXYZ");
const activeLetters = new Set(entries.map((entry) => entry.initial));
const creditGroups = tiers.map((tierConfig) => {
  const entriesForTier = entries.filter((entry) => entry.tier === tierConfig.tier);
  return {
    ...tierConfig,
    entries: entriesForTier,
    initialVisibleCount: entriesForTier.length,
  };
});
---

<section id="credit" class="credit-section surface-section py-18 sm:py-24" data-credit-section>
  <div class="credit-atmosphere" aria-hidden="true">
    <span></span><span></span>
  </div>

  <div class="container-page relative z-10">
    <div class="grid gap-8 lg:grid-cols-[0.86fr_1.14fr] lg:items-end">
      <SectionTitle title={copy.title} description={copy.description} />

      <div class="credit-console rounded-2xl border border-white/[0.12] bg-white/[0.07] p-5 shadow-card backdrop-blur sm:p-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-muted">{copy.directoryLabel}</p>
            <p class="mt-1 text-sm font-bold text-body">
              <span data-credit-total>{entries.length}</span> {copy.people}
            </p>
          </div>

          <button class="credit-sort" type="button" data-credit-sort data-sort-dir="asc" aria-label={copy.sort}>
            <span>{copy.sort}</span>
            <strong data-credit-sort-label>A-Z</strong>
          </button>
        </div>

        <label class="credit-search mt-5" aria-label={copy.searchLabel}>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="m21 21-4.35-4.35m1.35-5.65a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" />
          </svg>
          <input
            type="search"
            autocomplete="off"
            data-credit-search
            placeholder={copy.searchPlaceholder}
          />
        </label>

        <div class="mt-5">
          <p class="text-[0.68rem] font-extrabold uppercase tracking-[0.18em] text-muted">{copy.letterLabel}</p>
          <div class="credit-letters mt-3" role="group" aria-label={copy.letterLabel}>
            <button class="credit-letter is-active credit-letter--all" type="button" data-credit-letter="all" aria-pressed="true">
              {copy.all}
            </button>
            {alphabet.map((letter) => {
              const disabled = !activeLetters.has(letter);
              return (
                <button
                  class={`credit-letter ${disabled ? "is-disabled" : ""}`}
                  type="button"
                  data-credit-letter={letter}
                  aria-pressed="false"
                  disabled={disabled}
                >
                  {letter}
                </button>
              );
            })}
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 space-y-10">
      {creditGroups.map((group) => (
        <section class={`credit-tier-panel credit-tier-panel--${group.tier}`} data-credit-tier-panel={group.tier}>
          <div class="credit-tier-head">
            <div>
              <h3 class="display-heading text-3xl font-semibold text-ink sm:text-4xl">{group.title}</h3>
              <p class="mt-3 max-w-2xl text-sm leading-7 text-body">{group.description}</p>
            </div>
            <p class="credit-showing text-sm font-extrabold text-gold" data-credit-showing={group.tier}>
              {copy.showing} {group.initialVisibleCount} {copy.of} {group.entries.length}
            </p>
          </div>

          <div
            class="credit-grid mt-6 grid gap-2.5 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-5"
            data-credit-list
            data-credit-tier={group.tier}
            role="list"
          >
            {group.entries.map((entry) => (
              <article
                class={`credit-card credit-card--${group.tier} premium-card rounded-2xl p-3.5`}
                data-credit-card
                data-credit-tier={group.tier}
                data-credit-initial={entry.initial}
                data-credit-sort-key={entry.sortKey}
                data-credit-search-text={`${entry.name} ${entry.firstName} ${entry.role} ${entry.roleZh} ${entry.organization}`.toLowerCase()}
                role="listitem"
              >
                <div class="credit-card__glow" aria-hidden="true"></div>
                <h4 class="credit-card__name display-heading text-[1.58rem] font-semibold leading-[1.05] text-ink sm:text-[1.7rem]">{entry.name}</h4>
                <p class="credit-card__role-label mt-2 text-[0.8rem] font-bold text-body">
                  {entry.roleLines.map((line) => (
                    <span class={`credit-card__role-line credit-card__role-line--${line.kind}`}>{line.text}</span>
                  ))}
                </p>
              </article>
            ))}
          </div>

        </section>
      ))}
    </div>

    <p class="credit-empty mt-10 hidden rounded-2xl border border-white/[0.1] bg-white/[0.045] p-6 text-center text-sm font-bold text-body" data-credit-empty>
      {copy.empty}
    </p>
  </div>
</section>

<style>
  .credit-section {
    background:
      radial-gradient(ellipse at 8% 68%, rgba(var(--rgb-violet), 0.14), transparent 34rem),
      radial-gradient(ellipse at 92% 58%, rgba(var(--rgb-cyan-soft), 0.1), transparent 36rem),
      linear-gradient(180deg, rgba(var(--rgb-bg-deep), 0.72), rgba(var(--rgb-bg-base), 0.76));
    overflow: hidden;
    position: relative;
  }

  .credit-atmosphere {
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .credit-atmosphere span {
    border: 1px solid rgba(var(--rgb-cyan-soft), 0.1);
    border-radius: 999px;
    position: absolute;
  }

  .credit-atmosphere span:nth-child(1) {
    height: 30rem;
    left: -18rem;
    top: 4rem;
    width: 30rem;
  }

  .credit-atmosphere span:nth-child(2) {
    border-color: rgba(var(--rgb-violet-soft), 0.12);
    height: 36rem;
    right: -22rem;
    top: 20rem;
    width: 36rem;
  }

  .credit-search {
    align-items: center;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.045)),
      rgba(var(--rgb-bg-base), 0.46);
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 1.35rem;
    display: flex;
    gap: 0.8rem;
    min-height: 3.1rem;
    padding: 0 1rem;
    transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
  }

  .credit-search:focus-within {
    border-color: rgba(var(--rgb-cyan-soft), 0.58);
    box-shadow: 0 0 0 4px rgba(var(--rgb-cyan-soft), 0.07), 0 16px 32px rgba(var(--rgb-cyan-soft), 0.07);
    transform: translateY(-1px);
  }

  .credit-search svg {
    fill: none;
    height: 1.1rem;
    stroke: var(--cyan);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    width: 1.1rem;
  }

  .credit-search input {
    background: transparent;
    border: 0;
    color: var(--ink);
    flex: 1;
    font-size: 0.92rem;
    font-weight: 750;
    min-width: 0;
    outline: 0;
  }

  .credit-search input::placeholder {
    color: rgba(var(--rgb-body), 0.62);
  }

  .credit-sort,
  .credit-letter,
  .credit-load-more {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.13);
    color: var(--body);
    display: inline-flex;
    font-weight: 850;
    transition: background 220ms ease, border-color 220ms ease, color 220ms ease, transform 220ms ease;
  }

  .credit-sort,
  .credit-load-more {
    background: rgba(255, 255, 255, 0.07);
    border-radius: 999px;
    gap: 0.55rem;
    min-height: 2.65rem;
    padding: 0 0.95rem;
  }

  .credit-sort strong {
    color: var(--cyan);
    letter-spacing: 0.08em;
  }

  .credit-sort:hover,
  .credit-letter:hover:not(:disabled),
  .credit-letter.is-active,
  .credit-load-more:hover {
    background: rgba(var(--rgb-cyan-soft), 0.13);
    border-color: rgba(var(--rgb-cyan-soft), 0.52);
    color: var(--ink);
    transform: translateY(-2px);
  }

  .credit-letters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .credit-letter {
    background: rgba(255, 255, 255, 0.06);
    border-radius: 0.9rem;
    height: 2.2rem;
    justify-content: center;
    min-width: 2.2rem;
    padding: 0 0.65rem;
  }

  .credit-letter--all {
    min-width: 4.25rem;
  }

  .credit-letter.is-disabled {
    cursor: not-allowed;
    opacity: 0.28;
  }

  .credit-tier-panel {
    position: relative;
  }

  .credit-tier-panel.is-hidden {
    display: none;
  }

  .credit-grid {
    contain: layout paint style;
    content-visibility: auto;
    contain-intrinsic-size: auto 760px;
  }

  .credit-tier-head {
    align-items: end;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .credit-tier-panel--huge .credit-tier-head {
    background:
      radial-gradient(circle at 8% 0%, rgba(var(--rgb-warm), 0.11), transparent 18rem),
      linear-gradient(135deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.035));
    border: 1px solid rgba(var(--rgb-warm), 0.22);
    border-radius: 1.75rem;
    box-shadow: 0 18px 48px rgba(var(--rgb-warm), 0.055);
    padding: 1.25rem;
  }

  .credit-card {
    backdrop-filter: blur(18px) saturate(1.08);
    background:
      radial-gradient(circle at 16% 8%, rgba(var(--rgb-teal), 0.2), transparent 8.5rem),
      radial-gradient(circle at 88% 6%, rgba(var(--rgb-violet-soft), 0.13), transparent 8rem),
      linear-gradient(145deg, rgba(76, 105, 120, 0.28), rgba(18, 31, 57, 0.64) 52%, rgba(13, 21, 40, 0.78));
    border-color: rgba(var(--rgb-cyan-soft), 0.18);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -18px 44px rgba(var(--rgb-bg-deep), 0.24),
      0 18px 46px rgba(var(--rgb-bg-base), 0.2);
    contain: layout paint style;
    content-visibility: auto;
    contain-intrinsic-size: 7.5rem;
    min-height: 7.5rem;
    overflow: hidden;
    position: relative;
    transition: border-color 220ms ease, box-shadow 220ms ease, opacity 220ms ease, transform 220ms ease;
  }

  .credit-card::before {
    background:
      linear-gradient(135deg, rgba(var(--rgb-teal), 0.18), transparent 22%, transparent 72%, rgba(var(--rgb-ember), 0.07)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), transparent 48%);
    opacity: 0.64;
  }

  .credit-card::after {
    background:
      linear-gradient(120deg, transparent 0 33%, rgba(255, 255, 255, 0.07) 44%, transparent 56%),
      linear-gradient(54deg, transparent 0 45%, rgba(var(--rgb-teal), 0.07) 45.1% 45.42%, transparent 45.8%),
      radial-gradient(circle at 48% 0%, rgba(var(--rgb-teal), 0.12), transparent 48%);
    opacity: 0.64;
  }

  .credit-card:hover {
    border-color: rgba(var(--rgb-cyan-soft), 0.58);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 18px 48px rgba(var(--rgb-cyan-soft), 0.12);
    transform: translateY(-2px);
  }

  .credit-card--huge {
    border-color: rgba(var(--rgb-warm), 0.25);
    background:
      radial-gradient(circle at 16% 8%, rgba(var(--rgb-warm), 0.17), transparent 8.5rem),
      radial-gradient(circle at 86% 4%, rgba(var(--rgb-cyan-soft), 0.12), transparent 8rem),
      linear-gradient(145deg, rgba(91, 94, 103, 0.28), rgba(26, 32, 58, 0.64) 52%, rgba(14, 22, 42, 0.8));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 0 0 1px rgba(var(--rgb-warm), 0.04),
      0 22px 58px rgba(var(--rgb-warm), 0.08);
  }

  .credit-card--huge:hover {
    border-color: rgba(var(--rgb-warm), 0.48);
    box-shadow: 0 18px 50px rgba(var(--rgb-warm), 0.12);
  }

  .credit-card__glow {
    background:
      radial-gradient(circle at 20% 12%, rgba(var(--rgb-cyan-soft), 0.11), transparent 8rem),
      radial-gradient(circle at 80% 0%, rgba(var(--rgb-violet-soft), 0.09), transparent 7rem);
    inset: 0;
    mix-blend-mode: screen;
    opacity: 0.48;
    pointer-events: none;
    position: absolute;
  }

  .credit-card--huge .credit-card__glow {
    background:
      radial-gradient(circle at 22% 12%, rgba(var(--rgb-warm), 0.15), transparent 8rem),
      radial-gradient(circle at 86% 0%, rgba(var(--rgb-cyan-soft), 0.09), transparent 7rem);
  }

  .credit-card__name,
  .credit-card__role-label {
    position: relative;
    z-index: 1;
  }

  .credit-card__name {
    overflow-wrap: anywhere;
  }

  .credit-card__role-label {
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
    line-height: 1.42;
    overflow-wrap: anywhere;
  }

  .credit-card__role-line {
    display: block;
    max-width: 100%;
  }

  .credit-card__role-line--org {
    color: rgba(var(--rgb-body), 0.92);
    text-wrap: balance;
  }

  .credit-card__role-line--role {
    color: var(--ink);
    word-break: keep-all;
  }

  @media (max-width: 640px) {
    .credit-tier-head {
      align-items: start;
      flex-direction: column;
    }
  }
</style>

<script define:vars={{ copy }}>
  (() => {
    const section = document.querySelector("[data-credit-section]");
    if (!section || section.dataset.creditReady === "true") return;
    section.dataset.creditReady = "true";

    const search = section.querySelector("[data-credit-search]");
    const letters = [...section.querySelectorAll("[data-credit-letter]")];
    const sortButton = section.querySelector("[data-credit-sort]");
    const sortLabel = section.querySelector("[data-credit-sort-label]");
    const lists = new Map([...section.querySelectorAll("[data-credit-list]")].map((list) => [list.dataset.creditTier, list]));
    const cardsByTier = new Map([...lists].map(([tier, list]) => [tier, [...list.querySelectorAll("[data-credit-card]")]]));
    const panels = new Map([...section.querySelectorAll("[data-credit-tier-panel]")].map((panel) => [panel.dataset.creditTierPanel, panel]));
    const showingLabels = new Map([...section.querySelectorAll("[data-credit-showing]")].map((label) => [label.dataset.creditShowing, label]));
    const empty = section.querySelector("[data-credit-empty]");
    const totalLabel = section.querySelector("[data-credit-total]");
    const state = {
      direction: "asc",
      letter: "all",
      query: "",
    };

    const sortCards = (items) => {
      const direction = state.direction === "asc" ? 1 : -1;
      return [...items].sort((left, right) =>
        direction * (left.dataset.creditSortKey || "").localeCompare(right.dataset.creditSortKey || "", "en"),
      );
    };

    const matchesFilters = (card) => {
      const query = state.query.trim().toLowerCase();
      const letterMatch = state.letter === "all" || card.dataset.creditInitial === state.letter;
      const searchText = card.dataset.creditSearchText || "";
      return letterMatch && (!query || searchText.includes(query));
    };

    const updateLetters = () => {
      letters.forEach((button) => {
        const active = button.dataset.creditLetter === state.letter;
        button.classList.toggle("is-active", active);
        button.setAttribute("aria-pressed", String(active));
      });
    };

    const render = () => {
      let activeCount = 0;

      lists.forEach((list, tier) => {
        const cards = cardsByTier.get(tier) || [];
        const sortedCards = sortCards(cards);
        const matchingCards = sortedCards.filter(matchesFilters);
        const visibleSet = new Set(matchingCards);
        const panel = panels.get(tier);
        const showing = showingLabels.get(tier);
        const fragment = document.createDocumentFragment();

        activeCount += matchingCards.length;

        sortedCards.forEach((card) => {
          card.hidden = !visibleSet.has(card);
          fragment.appendChild(card);
        });

        list.appendChild(fragment);
        if (panel) panel.classList.toggle("is-hidden", matchingCards.length === 0);
        if (showing) showing.textContent = `${copy.showing} ${matchingCards.length} ${copy.of} ${matchingCards.length}`;
      });

      if (totalLabel) totalLabel.textContent = String(activeCount);
      if (empty) empty.classList.toggle("hidden", activeCount > 0);

      updateLetters();
    };

    let renderQueued = false;
    const scheduleRender = () => {
      if (renderQueued) return;
      renderQueued = true;
      window.requestAnimationFrame(() => {
        renderQueued = false;
        render();
      });
    };

    search?.addEventListener("input", (event) => {
      state.query = event.currentTarget.value || "";
      scheduleRender();
    });

    letters.forEach((button) => {
      button.addEventListener("click", () => {
        if (button.disabled) return;
        state.letter = button.dataset.creditLetter || "all";
        render();
      });
    });

    sortButton?.addEventListener("click", () => {
      state.direction = state.direction === "asc" ? "desc" : "asc";
      sortButton.dataset.sortDir = state.direction;
      if (sortLabel) sortLabel.textContent = state.direction === "asc" ? "A-Z" : "Z-A";
      render();
    });

    render();
  })();
</script>
