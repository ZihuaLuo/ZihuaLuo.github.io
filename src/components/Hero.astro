---
import AvatarCard from "@components/AvatarCard.astro";
import CTAButton from "@components/CTAButton.astro";
import HeroAtmosphere from "@components/HeroAtmosphere.astro";
import HeroMusicPlayer from "@components/HeroMusicPlayer.astro";
import { langPath, withBase, type Language } from "@i18n/routes";
import { personalSignature, siteInfo } from "@i18n/ui";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const headingLeading = lang === "zh" ? "leading-[1.12]" : "leading-[0.98]";
const donationHref = withBase("/documents/un-women-donation-confirmation.pdf");
const nutritionDonationHref = withBase("/documents/children-nutrition-donation-certificate-bilingual.png");
const proposalSeparator = lang === "zh" ? "：" : ": ";
const copy = {
  en: {
    eyebrow: "About Me",
    name: siteInfo.englishName,
    tagline: personalSignature.en,
    proposalLabel: "Belief",
    proposal: "The world deserves better.",
    donation: "CA$1,000 donation to UN Women",
    nutritionDonation: "Bilingual RMB 1,000 nutrition meal certificate",
    primary: "Read Thinking",
    quickLinks: [
      { label: "Impact Metrics", href: "#impact", variant: "secondary" as const },
      { label: "Credits", href: "#credit", variant: "secondary" as const },
    ],
    metrics: [
      ["01", "Sincere"],
      ["02", "Optimistic"],
      ["03", "Resilient"],
    ],
  },
  zh: {
    eyebrow: "关于我",
    name: siteInfo.zhDisplayName,
    tagline: personalSignature.zh,
    proposalLabel: "信念",
    proposal: "世界值得变得更好。",
    donation: "向联合国妇女署捐赠 CA$1,000",
    nutritionDonation: "RMB 1,000 营养餐捐赠双语证书",
    primary: "阅读思考内容",
    quickLinks: [
      { label: "量化成果", href: "#impact", variant: "secondary" as const },
      { label: "致谢", href: "#credit", variant: "secondary" as const },
    ],
    metrics: [
      ["01", "真诚"],
      ["02", "乐观"],
      ["03", "抗压"],
    ],
  },
}[lang];

const heroHref = (href: string) => href.startsWith("#") ? href : langPath(lang, href);
const donationLinks = [
  { label: copy.donation, href: donationHref },
  { label: copy.nutritionDonation, href: nutritionDonationHref },
];
---

<section class="finance-hero py-14 sm:py-18 lg:py-24">
  <HeroAtmosphere />
  <div class="container-page relative z-10 grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="order-2 max-w-3xl text-ink lg:order-1">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-accent/25 bg-white/[0.08] px-3.5 py-1.5 text-sm font-bold text-ink shadow-[0_0_34px_rgba(124,58,237,0.16),inset_0_1px_0_rgba(255,255,255,0.12)] backdrop-blur">
        <span class="h-1.5 w-1.5 rounded-full bg-accent shadow-[0_0_18px_rgba(56,189,248,0.75)]" aria-hidden="true"></span>
        {copy.eyebrow}
      </div>
      <h1 class={`display-heading title-flow title-flow--hero max-w-4xl bg-[linear-gradient(135deg,var(--text-primary)_0%,#DBEAFE_42%,var(--text-violet)_82%)] bg-clip-text text-5xl font-semibold ${headingLeading} text-transparent sm:text-6xl lg:text-7xl`}>
        {copy.name}
      </h1>
      <div class="mt-5 max-w-2xl">
        <p class="hero-signature text-3xl font-bold leading-snug text-ink sm:text-4xl">
          {copy.tagline}
        </p>

        <div class="mt-4 inline-flex w-fit max-w-full flex-col items-start rounded-2xl border border-white/[0.11] bg-white/[0.045] p-4 shadow-[0_16px_42px_rgba(56,189,248,0.045),inset_0_1px_0_rgba(255,255,255,0.08)] backdrop-blur">
          <p class="text-base font-bold leading-8 text-[#B99754] sm:text-lg">
            {copy.proposalLabel}{proposalSeparator}{copy.proposal}
          </p>
          <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:flex-wrap">
            {donationLinks.map((item) => (
              <a
                class="inline-flex w-fit max-w-full items-center gap-2 rounded-full border border-[#6F5622]/60 bg-[#2D2110]/62 px-3.5 py-2 text-xs font-extrabold tracking-[0.08em] text-[#D6A85C] shadow-[0_0_22px_rgba(214,168,92,0.1),inset_0_1px_0_rgba(255,255,255,0.08)] transition hover:-translate-y-0.5 hover:border-[#D6A85C]/80 hover:bg-[#3A2A13]/82 hover:text-[#F1D08A]"
                href={item.href}
                target="_blank"
                rel="noreferrer"
              >
                <span class="min-w-0">{item.label}</span>
                <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <CTAButton href={langPath(lang, "/thoughts/")} label={copy.primary} />
        {copy.quickLinks.map((link) => (
          <CTAButton href={heroHref(link.href)} label={link.label} variant={link.variant} />
        ))}
      </div>

      <HeroMusicPlayer lang={lang} />

      <div class="mt-11 grid max-w-3xl gap-4 sm:grid-cols-3">
        {copy.metrics.map(([number, label]) => (
          <div class="hero-metric min-h-20 rounded-2xl border border-accent/22 bg-[linear-gradient(135deg,rgba(255,255,255,0.12),rgba(255,255,255,0.055))] p-3.5 shadow-[0_16px_44px_rgba(56,189,248,0.07),inset_0_1px_0_rgba(255,255,255,0.12)] backdrop-blur transition hover:-translate-y-1 hover:border-accent/60 hover:bg-white/[0.14] hover:shadow-lift">
            <p class="text-sm font-extrabold text-accent">{number}</p>
            <p class="mt-2 text-2xl font-extrabold leading-tight text-ink sm:text-3xl">{label}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="order-1 lg:order-2">
      <AvatarCard lang={lang} />
    </div>
  </div>
</section>
