---
interface Props {
  label: string;
  inverse?: boolean;
}

const { label } = Astro.props;
const classes = "border-line bg-white/[0.08] text-body hover:border-accent/45 hover:text-ink";
---

<span class={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-bold shadow-sm transition ${classes}`}>
  {label}
</span>
