---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
import NowDashboard from "@components/NowDashboard.astro";
import { siteInfo } from "@i18n/ui";
---

<BaseLayout
  title={`量化成果 | ${siteInfo.zhDisplayName}`}
  description="罗子华，FRM 的学业表现、证书进度、工作执行、职业社交与分析规模量化记录"
  lang="zh"
  alternateHref="/now/"
  canonicalPath="/zh/now/"
>
  <section class="finance-shell py-14 sm:py-20">
    <div class="container-page relative z-10">
      <PageHeader
        eyebrow="成果"
        title="量化成果"
        description="用数字记录学业表现、证书进度、工作执行、职业社交与分析规模"
      />
    </div>
  </section>

  <section class="surface-section now-section py-18 sm:py-24">
    <div class="container-page">
      <NowDashboard lang="zh" showHeader={false} />
    </div>
  </section>
</BaseLayout>
