---
import { getCollection, render } from "astro:content";
import ContentLayout from "@layouts/ContentLayout.astro";
import { entrySlug } from "@i18n/routes";

export async function getStaticPaths() {
  const includeDrafts = !import.meta.env.PROD;
  const all = await getCollection("thoughts", ({ data }) => includeDrafts || !data.draft);
  const entries = all.filter((entry) => entry.data.language === "en");

  return entries.map((entry) => {
    const slug = entrySlug(entry.id);
    const counterpart = all.find(
      (candidate) =>
        candidate.data.language === "zh" &&
        candidate.data.translationKey === entry.data.translationKey,
    );
    const alternateHref = counterpart ? `/zh/thoughts/${entrySlug(counterpart.id)}/` : "/zh/";

    return {
      params: { slug },
      props: {
        entry,
        alternateHref,
        canonicalPath: `/thoughts/${slug}/`,
      },
    };
  });
}

const { entry, alternateHref, canonicalPath } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout
  entry={entry}
  lang="en"
  collection="thoughts"
  alternateHref={alternateHref}
  canonicalPath={canonicalPath}
>
  <Content />
</ContentLayout>
