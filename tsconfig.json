---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/PageHeader.astro";
import NoteCard from "@components/NoteCard.astro";
import Tag from "@components/Tag.astro";
import { entrySlug, langPath } from "@i18n/routes";
import { siteInfo } from "@i18n/ui";

const lang = "en";
const includeDrafts = !import.meta.env.PROD;
const notes = (await getCollection(
  "notes",
  ({ data }) => data.language === lang && (includeDrafts || !data.draft),
)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const grouped = notes.reduce<Record<string, typeof notes>>((acc, entry) => {
  acc[entry.data.category] ??= [];
  acc[entry.data.category].push(entry);
  return acc;
}, {});

const categories = [
  "CFA Level II",
  "Financial Statement Analysis",
  "Fixed Income",
  "Derivatives",
  "Equity Valuation",
  "Portfolio Management",
  "Economics",
  "Data Analytics",
];
---

<BaseLayout
  title={`Notes | ${siteInfo.englishName}`}
  description="A structured learning system by Zihua Luo, FRM for CFA Level II, financial analysis, fixed income, derivatives, equity valuation, portfolio management, economics, and data analytics"
  lang={lang}
  alternateHref="/zh/notes/"
  canonicalPath="/notes/"
>
  <section class="finance-shell py-14 sm:py-20">
    <div class="container-page relative z-10 grid gap-8 lg:grid-cols-[1fr_0.62fr] lg:items-end">
      <PageHeader
        eyebrow="Notes"
        title="A structured learning system for finance and analytics"
        description="Notes are more concise than essays, but the archive is organized so CFA concepts and finance frameworks can compound over time"
        tone="dark"
      />
      <div class="premium-card rounded-lg p-5">
        <p class="eyebrow mb-4">Knowledge Map</p>
        <div class="flex flex-wrap gap-2" aria-label="Note categories">
          {categories.map((category) => <Tag label={category} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="surface-section archive-section archive-section--notes py-18 sm:py-24">
    <div class="container-page grid gap-10">
      {Object.entries(grouped).map(([category, entries]) => (
        <section>
          <div class="mb-5 flex items-center gap-4">
            <h2 class="display-heading text-3xl font-semibold text-ink">{category}</h2>
            <span class="h-px flex-1 bg-line" aria-hidden="true"></span>
            <span class="text-xs font-bold text-gold">{entries.length} notes</span>
          </div>
          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {entries.map((entry) => (
              <NoteCard entry={entry} lang={lang} href={langPath(lang, `/notes/${entrySlug(entry.id)}/`)} />
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
