---
import { withBase } from "@i18n/routes";

interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary" | "ghost";
}

const { href, label, variant = "primary" } = Astro.props;
const styles = {
  primary:
    "border-accent/60 bg-[linear-gradient(135deg,var(--cyan)_0%,var(--text-violet)_48%,var(--accent-2)_100%)] text-[var(--bg-base)] shadow-[0_0_34px_var(--glow-cyan),inset_0_1px_0_rgba(255,255,255,0.5)] hover:-translate-y-0.5 hover:shadow-lift",
  secondary:
    "border-accent/25 bg-white/[0.1] text-ink shadow-[inset_0_1px_0_rgba(255,255,255,0.12)] hover:-translate-y-0.5 hover:border-accent/70 hover:bg-white/[0.14] hover:shadow-lift",
  ghost:
    "border-line bg-white/[0.045] text-body hover:-translate-y-0.5 hover:border-violet/70 hover:bg-white/[0.09] hover:text-ink",
}[variant];
---

<a
  href={withBase(href)}
  class={`group relative inline-flex min-h-12 items-center justify-center overflow-hidden rounded-full border px-5 text-sm font-extrabold transition duration-300 ${styles}`}
>
  <span class="absolute inset-y-0 -left-1/3 w-1/3 bg-gradient-to-r from-transparent via-white/35 to-transparent opacity-0 transition duration-500 group-hover:left-full group-hover:opacity-70" aria-hidden="true"></span>
  <span class="relative">{label}</span>
</a>
